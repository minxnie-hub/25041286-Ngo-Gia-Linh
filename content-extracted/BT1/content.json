      "images": [
        "image15.png"
      ]
    },
    {
      "type": "paragraph",
      "style": "Normal",
      "text": "Nhấp chuột phải vào tệp DiChuyen.txt -> chọn Cut (hoặc chọn tệp rồi nhấn Ctrl + X).",
      "images": [
        "image16.png"
      ]
